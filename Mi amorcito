                mostrarContenidoCarta(index);
            }, 100);
        }

        function mostrarContenidoCarta(index) {
            const tituloModal = `${categoriaActiva === 'amarillo' ? 'Felicidad 💛' : categoriaActiva === 'rojo' ? 'Enojo ❤️' : 'Tristeza 💙'}`;
            const textoModal = subCartasData[categoriaActiva][index];

            document.getElementById("tituloCarta").innerText = tituloModal;
            document.getElementById("textoCarta").innerText = textoModal;
            document.getElementById("modalCarta").style.display = "flex";
        }

        // Lógica especial para la carta de bienvenida (Rosa)
        function abrirCartaDirecta(tipo, event) {
            if (event) {
                explosionDeCorazones(event.clientX, event.clientY);
            }
            const textoRosa = "Bienvenida a nuestro rincón secreto, mi vida 💗 Este lugar es solo para ti y para mí, para que encuentres cartitas mías sin necesidad de que sea San Valentín, tu cumpleaños o cualquier otra fecha del calendario. Porque contigo, cada día es especial y merece ser celebrado. Te amo mucho, te amo más de lo que las palabras pueden expresar, y quiero que sepas que siempre estaré a tu lado, apoyándote, cuidándote y amándote sin importar qué pase. Eres mi todo 💗";
            
            document.getElementById("tituloCarta").innerText = "Para: Mi Princesita 💗";
            document.getElementById("textoCarta").innerText = textoRosa;
            document.getElementById("modalCarta").style.display = "flex";
        }

        function cerrarModal() {
            document.getElementById("modalCarta").style.display = "none";
        }

        // Cerrar modal si se hace clic fuera de la cartita
        window.onclick = function(event) {
            const modalCarta = document.getElementById("modalCarta");
            if (event.target == modalCarta) {
                cerrarModal();
            }
        }
    </script>
</body>
</html>
