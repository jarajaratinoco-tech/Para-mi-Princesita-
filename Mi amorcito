        // 5. Inyección dinámica de las 15 cartas con retraso de animación (efecto cascada)
        function irASubCartas(categoria, titulo) {
            categoriaActiva = categoria;
            document.getElementById("subCartasTitulo").innerText = `Tus Cartas de ${titulo}`;
            
            const contenedor = document.getElementById("contenedor15Cartas");
            contenedor.innerHTML = ""; // Vaciar anterior

            // Crear las 15 cartas desbloqueadas por defecto
            for (let i = 0; i < 15; i++) {
                const carta = document.createElement("div");
                carta.className = `sub-carta tema-${categoria}`;
                carta.setAttribute("onclick", `interaccionSubCarta(${i}, event)`);
                
                // Se asigna dinámicamente un delay a la animación para simular el efecto ola
                carta.style.animationDelay = `${i * 0.04}s`;
                
                // Mostrar directamente el icono de la cartita de amor
                carta.innerHTML = `
                    <div class="sub-carta-icon">💌</div>
                    <div class="sub-carta-num">Carta ${i + 1}</div>
                `;
                contenedor.appendChild(carta);
            }

            transicionSecciones("seccionCartas", "seccionSubCartas");
        }

